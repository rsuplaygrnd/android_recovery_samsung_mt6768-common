Author: ravindu644 <droidcasts@protonmail.com>
Date:   Sat Dec 6 14:37:18 2025 +0530

    [2/2] Haptics: Implement Max Vibration intensity in TWRP 12.1
    
    Signed-off-by: ravindu644 <droidcasts@protonmail.com>

diff --git a/bootable/recovery/gui/slidervalue.cpp b/bootable/recovery/gui/slidervalue.cpp
index 8deb9e081e..ce121e81de 100755
--- a/bootable/recovery/gui/slidervalue.cpp
+++ b/bootable/recovery/gui/slidervalue.cpp
@@ -135,6 +135,20 @@ GUISliderValue::GUISliderValue(xml_node<>* node) : GUIObject(node)
 			mMax = atoi(mMaxStr.c_str());
 		}
 
+		// Clamp vibration slider max values to TW_MAX_VIBRATION_INTENSITY if defined
+		if (!mVariable.empty() && (
+			mVariable == "tw_button_vibrate" ||
+			mVariable == "tw_keyboard_vibrate" ||
+			mVariable == "tw_action_vibrate"))
+		{
+#ifdef TW_MAX_VIBRATION_INTENSITY
+			if (mMax > TW_MAX_VIBRATION_INTENSITY) {
+				mMax = TW_MAX_VIBRATION_INTENSITY;
+				mMaxStr = std::to_string(mMax);
+			}
+#endif
+		}
+
 		if (mMin > mMax)
 			mMin = mMax;
 
